---
/**
 * Custom 404 Page
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" description="The page you're looking for doesn't exist">
  <div class="error-page">
    <div class="container">
      <div class="error-content">
        <div class="error-illustration">
          <svg width="200" height="200" viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="2" opacity="0.2"/>
            <text x="50%" y="50%" text-anchor="middle" dy=".3em" font-size="80" font-weight="700" fill="currentColor">
              404
            </text>
          </svg>
        </div>

        <h1 class="error-title">Page Not Found</h1>
        <p class="error-description">
          Sorry, we couldn't find the page you're looking for. It might have been moved, deleted, or perhaps never existed.
        </p>

        <div class="error-actions">
          <a href="/" class="button button-primary">Go Home</a>
          <a href="/blog" class="button button-secondary">Browse Blog</a>
        </div>

        <div class="error-search">
          <p>Or search for something:</p>
          <a href="/search" class="search-link">Open Search →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
  }

  .error-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .error-illustration {
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .error-illustration svg {
    width: 200px;
    height: 200px;
    margin: 0 auto;
  }

  .error-title {
    font-size: clamp(2rem, 5vw, 2.5rem);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .error-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .error-search {
    padding: 2rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .error-search p {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }

  .search-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .search-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
    }

    .error-illustration svg {
      width: 150px;
      height: 150px;
    }
  }
</style>
