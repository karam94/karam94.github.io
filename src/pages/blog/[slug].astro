---
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { generateExcerpt } from '../../utils/generateExcerpt';
import { getRelatedPosts } from '../../utils/getRelatedPosts';
import { getSlug } from '../../utils/getSlug';
import { getReadingTime } from '../../utils/getReadingTime';
import type { RelatedPost } from '../../utils/getRelatedPosts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    return {
      params: { slug: getSlug(post.id) },
      props: { post, allPosts: posts },
    };
  });
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();

// Calculate reading time from raw markdown body (not rendered HTML)
const calculatedReadingTime = post.data.readingTime || getReadingTime(post.body);

// Get content for excerpt generation
const { body: renderedContent } = await post.render();
const excerpt = post.data.excerpt || generateExcerpt(renderedContent, 200);

// Get related posts
const relatedPosts = getRelatedPosts(post.data.category, allPosts, getSlug(post.id));

// Generate blog posting structured data
const blogPostingData = {
  title: post.data.title,
  description: post.data.description,
  image: post.data.heroImage ? new URL(post.data.heroImage, Astro.site).href : undefined,
  pubDate: post.data.pubDate.toISOString(),
  updatedDate: post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
  url: Astro.url.href,
};
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  heroImage={post.data.heroImage}
  category={post.data.category}
  readingTime={calculatedReadingTime}
  excerpt={excerpt}
  series={post.data.series}
  relatedPosts={relatedPosts}
  structuredDataType="BlogPosting"
  structuredDataData={blogPostingData}
>
  <Content />
</BlogPostLayout>
