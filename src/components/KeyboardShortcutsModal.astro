---
/**
 * Keyboard Shortcuts Modal Component
 * Shows available keyboard shortcuts (triggered by ? key)
 */
---

<dialog id="shortcuts-modal" class="shortcuts-modal">
  <div class="shortcuts-content">
    <div class="shortcuts-header">
      <h2>Keyboard Shortcuts</h2>
      <button id="shortcuts-close" class="shortcuts-close" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 12M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="shortcuts-list">
      <div class="shortcut-item">
        <span class="shortcut-desc">Open this help</span>
        <kbd>?</kbd>
      </div>
      <div class="shortcut-item">
        <span class="shortcut-desc">Focus search</span>
        <div class="shortcut-keys">
          <kbd>⌘</kbd><kbd>K</kbd>
        </div>
      </div>
      <div class="shortcut-item">
        <span class="shortcut-desc">Scroll to top</span>
        <div class="shortcut-keys">
          <kbd>fn</kbd><kbd>↑</kbd>
        </div>
      </div>
      <div class="shortcut-item">
        <span class="shortcut-desc">Close modal</span>
        <kbd>Esc</kbd>
      </div>
    </div>

    <p class="shortcuts-note">Press <kbd>?</kbd> or <kbd>Esc</kbd> to close</p>
  </div>
</dialog>

<style>
  .shortcuts-modal {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 100%;
  }

  .shortcuts-modal::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .shortcuts-content {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem;
    width: 90vw;
    max-width: 480px;
  }

  .shortcuts-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .shortcuts-header h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  .shortcuts-close {
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .shortcuts-close:hover {
    color: var(--color-text);
  }

  .shortcuts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .shortcut-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
  }

  .shortcut-desc {
    color: var(--color-text);
    font-size: 1rem;
  }

  .shortcut-keys {
    display: flex;
    gap: 0.25rem;
  }

  kbd {
    padding: 0.25rem 0.5rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .shortcuts-note {
    text-align: center;
    margin-top: 2rem;
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .shortcuts-note kbd {
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .shortcuts-close {
      transition: none;
    }
  }
</style>

<script>
  const modal = document.getElementById('shortcuts-modal')! as HTMLDialogElement;
  const closeBtn = document.getElementById('shortcuts-close')!;

  function openModal() {
    modal.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.close();
    document.body.style.overflow = '';
  }

  // Close button
  closeBtn.addEventListener('click', closeModal);

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // ? to open
    if (e.key === '?' && !e.metaKey && !e.ctrlKey) {
      // Only if not typing in an input
      const target = e.target as HTMLElement;
      if (target.tagName !== 'INPUT' && target.tagName !== 'TEXTAREA') {
        e.preventDefault();
        openModal();
      }
    }

    // Esc to close
    if (e.key === 'Escape' && modal.open) {
      closeModal();
    }
  });

  // Re-init after page transitions
  document.addEventListener('astro:page-load', () => {
    const newModal = document.getElementById('shortcuts-modal');
    const newCloseBtn = document.getElementById('shortcuts-close');
    if (newModal && newCloseBtn) {
      newCloseBtn.addEventListener('click', () => {
        newModal.close();
        document.body.style.overflow = '';
      });
    }
  });
</script>
