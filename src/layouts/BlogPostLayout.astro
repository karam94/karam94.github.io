---
import BaseLayout from './BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { formatDate } from '../utils/formatDate';

import RelatedPosts from '../components/RelatedPosts.astro';
import type { RelatedPost } from '../utils/getRelatedPosts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  readingTime?: number;
  excerpt?: string;
  series?: string;
  relatedPosts?: RelatedPost[];
  structuredDataType?: 'BlogPosting' | 'BreadcrumbList' | 'Person' | 'WebSite';
  structuredDataData?: Record<string, any>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  readingTime,
  excerpt,
  series,
  relatedPosts,
  structuredDataType,
  structuredDataData,
} = Astro.props;

const type = 'article';
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type={type}
  publishDate={pubDate}
  modifiedDate={updatedDate}
  structuredDataType={structuredDataType}
  structuredDataData={structuredDataData}
>
  <article class="blog-post">
    <header class="blog-post-header">
      <div class="container">
        <h1 class="blog-post-title">{title}</h1>

        <div class="blog-post-meta">
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
          {readingTime && (
            <>
              <span class="separator">•</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </div>

        <div class="blog-post-category">
          <span class="category">{category}</span>
        </div>

        <div class="share-buttons">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-button"
            aria-label="Share on X"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-button"
            aria-label="Share on LinkedIn"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(Astro.url.href)}`}
            class="share-button"
            aria-label="Share via Email"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </a>
          <button
            class="share-button copy-link"
            aria-label="Copy link"
            data-url={Astro.url.href}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    {heroImage && (
      <div class="hero-image">
        <OptimizedImage
          src={heroImage}
          alt={`Featured image for: ${title}`}
          width={1200}
          height={630}
          sizes="100vw"
          loading="eager"
          priority
        />
      </div>
    )}

    <div class="container">
      <div class="blog-post-content prose">
        <slot />
      </div>

      {relatedPosts && relatedPosts.length > 0 && (
        <RelatedPosts posts={relatedPosts} />
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 4rem 0;
  }

  .blog-post-header {
    text-align: left;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    background: none;
  }

  .blog-post-title {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .blog-post-meta {
    display: inline-flex;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: none;
    padding: 0;
    box-shadow: none;
  }

  .separator {
    color: var(--color-text-muted);
  }

  .blog-post-category {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .category {
    background: var(--color-accent-muted);
    color: var(--color-accent);
    border: none;
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-family: var(--font-mono);
  }

  .share-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .share-button {
    color: var(--color-text);
    opacity: 0.6;
    transition: opacity var(--transition-fast), transform var(--transition-fast), color var(--transition-fast);
    display: flex;
    align-items: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .share-button:hover {
    opacity: 1;
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .hero-image {
    max-width: 70ch;
    margin: 2rem auto;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Prose styles for markdown content */
  .prose {
    max-width: 70ch;
    margin: 0 auto;
    font-size: 1.0625rem;
    line-height: 1.8;
    font-weight: 350;
    content-visibility: auto;
    contain-intrinsic-size: auto 1000px;
  }

  .prose :global(h2) {
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 1.875rem;
  }

  .prose :global(h3) {
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    font-weight: 350;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
    font-weight: 350;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 2rem;
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
  }

  .prose :global(blockquote::before) {
    display: none;
  }

  .prose :global(pre) {
    font-family: var(--font-code);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85em;
  }

  .prose :global(pre::before) {
    display: none;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2rem 0;
  }

  .prose :global(code:not(pre code)) {
    font-family: var(--font-code);
    font-size: 0.9em;
    font-weight: 700;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem;
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-card-bg);
    font-weight: 600;
  }
</style>

<script>
  document.querySelector('.copy-link')?.addEventListener('click', async (e) => {
    const button = e.currentTarget as HTMLButtonElement;
    const url = button.dataset.url;
    if (url) {
      await navigator.clipboard.writeText(url);
      button.classList.add('copied');
      setTimeout(() => button.classList.remove('copied'), 2000);
    }
  });
</script>
